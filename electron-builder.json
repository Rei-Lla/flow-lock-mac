{
  "appId": "com.flowlock.app",
  "productName": "心流锁定器",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "package.json"
  ],
  "mac": {
    "target": [
      {
        "target": "dmg",
        "arch": ["universal"]
      }
    ],
    "category": "public.app-category.productivity",
    "entitlements": "entitlements.mac.plist",
    "entitlementsInherit": "entitlements.mac.plist",
    "extendInfo": {
      "NSAppleEventsUsageDescription": "心流锁定器需要检测运行中的应用并在锁定期间管理焦点。"
    }
  },
  "dmg": {
    "title": "心流锁定器"
  }
}
